---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Services from "../components/sections/Services.astro";
import Work from "../components/sections/Work.astro";
import Blog from "../components/sections/Blog.astro";
import Contact from "../components/sections/Contact.astro";
import Hairline from "../components/Hairline.astro";
import { SITE } from "../lib/site";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  jobTitle: SITE.role,
  description: SITE.tagline,
  url: "https://edwinfredkamau.co.ke",
  image: "https://edwinfredkamau.co.ke/og-image.png",
  email: SITE.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Nairobi",
    addressCountry: "KE",
  },
  worksFor: {
    "@type": "Organization",
    name: "Lobster Technologies",
  },
  sameAs: [SITE.linkedin, SITE.x, SITE.github],
};
---

<BaseLayout
  title={`${SITE.name} — Software & AI Engineer in Nairobi, Kenya`}
  description={SITE.tagline}
  schema={personSchema}
>
  <Hero />

  <Hairline class="container" />
  <About />

  <Hairline class="container" />
  <Services />

  <Hairline class="container" />
  <Work />

  <Hairline class="container" />
  <Blog />

  <Hairline class="container" />
  <Contact />
</BaseLayout>
