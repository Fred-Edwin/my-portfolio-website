---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Services from "../components/sections/Services.astro";
import Work from "../components/sections/Work.astro";
import Blog from "../components/sections/Blog.astro";
import Contact from "../components/sections/Contact.astro";
import Hairline from "../components/Hairline.astro";
import { SITE } from "../lib/site";

// One linked graph: WebSite → Person → Organization, plus the two flagship
// products as CreativeWorks the Person created. Cross-referenced by @id so
// search engines and AI models resolve them as one entity, not loose nodes.
const SITE_URL = "https://edwinfredkamau.co.ke";
const PERSON_ID = `${SITE_URL}/#person`;
const ORG_ID = `${SITE.company.url}#organization`;

const orgSchema = {
  "@type": "Organization",
  "@id": ORG_ID,
  name: SITE.company.name,
  url: SITE.company.url,
  founder: { "@id": PERSON_ID },
  areaServed: "East Africa",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Nairobi",
    addressCountry: "KE",
  },
};

const personSchema = {
  "@type": "Person",
  "@id": PERSON_ID,
  name: SITE.name,
  jobTitle: SITE.role,
  description: SITE.tagline,
  url: SITE_URL,
  image: `${SITE_URL}/og-image.png`,
  email: SITE.email,
  telephone: SITE.phone,
  knowsAbout: [...SITE.expertise],
  knowsLanguage: ["en", "sw"],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Nairobi",
    addressCountry: "KE",
  },
  worksFor: { "@id": ORG_ID },
  founder: { "@id": ORG_ID },
  sameAs: [SITE.linkedin, SITE.x, SITE.github, SITE.company.url],
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  url: SITE_URL,
  name: `${SITE.name} — ${SITE.role}`,
  description: SITE.tagline,
  inLanguage: "en",
  author: { "@id": PERSON_ID },
  publisher: { "@id": PERSON_ID },
};

// The flagship systems, marked up so an AI summarising "what has Edwinfred
// built" reads them as concrete works, not inferred prose.
const projectSchemas = [
  {
    "@type": "SoftwareApplication",
    name: "Wendo Coffee & Bistro — restaurant management system & POS",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, Android, iOS",
    description:
      "A restaurant management system and POS, built in Kenya, running the floor, kitchen, and books across every branch as one — real-time order routing, GPS staff clock-in, live branch dashboards, payments, credit accounts, HR, and reporting.",
    creator: { "@id": PERSON_ID },
    author: { "@id": PERSON_ID },
    areaServed: "Kenya",
  },
  {
    "@type": "SoftwareApplication",
    name: "Washan Groceries — business management system for a wholesaler",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, Android, iOS",
    description:
      "A mobile-first business management system for a grocery wholesaler in Kenya: per-client pricing, a running credit ledger, stock across locations, and branded PDF invoices — the whole business in the owner's pocket.",
    creator: { "@id": PERSON_ID },
    author: { "@id": PERSON_ID },
    areaServed: "Kenya",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [websiteSchema, personSchema, orgSchema, ...projectSchemas],
};
---

<BaseLayout
  title={`${SITE.name} — Software & AI Developer in Nairobi, Kenya`}
  description="Edwinfred Kamau — software developer and AI developer in Nairobi, Kenya. I build custom software, business management systems, restaurant POS, ERP, and AI automation for growing businesses across Kenya and East Africa."
  schema={schema}
>
  <Hero />

  <Hairline class="container" />
  <About />

  <Hairline class="container" />
  <Services />

  <Hairline class="container" />
  <Work />

  <Hairline class="container" />
  <Blog />

  <Hairline class="container" />
  <Contact />
</BaseLayout>
